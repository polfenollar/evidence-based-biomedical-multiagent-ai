{
  "title": "Biomedical AI — SLO Dashboard",
  "uid": "biomedical-slo-v1",
  "version": 1,
  "schemaVersion": 37,
  "tags": ["biomedical", "slo"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Query Success Rate (approved / total)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(biomedical_queries_total{status=\"approved\"}[5m])) / sum(rate(biomedical_queries_total[5m]))",
          "legendFormat": "Success rate"
        }
      ]
    },
    {
      "id": 2,
      "title": "Query Volume by Status (5m rate)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 16, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (status) (rate(biomedical_queries_total[5m]))",
          "legendFormat": "{{ status }}"
        }
      ]
    },
    {
      "id": 3,
      "title": "P95 Query Latency",
      "type": "stat",
      "gridPos": { "x": 0, "y": 4, "w": 8, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(biomedical_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95 latency"
        }
      ]
    },
    {
      "id": 4,
      "title": "Query Latency Distribution",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 4, "w": 16, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(biomedical_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(biomedical_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(biomedical_query_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 5,
      "title": "DQ Violation Rate (5m rate)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (rule) (rate(biomedical_dq_violations_total[5m]))",
          "legendFormat": "{{ rule }}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Total Queries (all time)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(biomedical_queries_total)",
          "legendFormat": "Total queries"
        }
      ]
    },
    {
      "id": 7,
      "title": "DQ Violations (all time)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(biomedical_dq_violations_total)",
          "legendFormat": "DQ violations"
        }
      ]
    }
  ]
}
